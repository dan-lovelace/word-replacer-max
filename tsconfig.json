{
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@worm/background": ["./packages/background"],
      "@worm/content": ["./packages/content"],
      "@worm/plugins": ["./packages/plugins"],
      "@worm/popup": ["./packages/popup"],
      "@worm/shared": ["./packages/shared"],
      "@worm/testing": ["./packages/testing"],
      "@worm/types": ["./packages/types"],
      "@worm/webapp": ["./packages/webapp"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "useDefineForClassFields": true
  }
}
